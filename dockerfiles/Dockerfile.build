ARG CCACHE_DIR="/ccache"
ARG CCACHE_LOC="/source"
ARG COMMAND="${CCACHE_LOC}/ci/build"
ARG INTERACTIVE
ARG ASAN_OPTIONS
ARG EXTRA_CMAKE_BUILD_FLAGS
ARG CC
ARG CFLAGS
ARG CMAKE_PARAMS
ARG CXX
ARG CXXFLAGS
ARG LDFLAGS
ARG NO_TEST
ARG SCAN_BUILD
ARG SPECIAL
ARG VERBOSE

WORKDIR ${CCACHE_LOC}

COPY --exclude=.git* --exclude=dockerfiles . ${CCACHE_LOC}
ARG BASE_IMAGE
ARG TARGETPLATFORM
RUN CMAKE_PARAMS="`./misc/get-arch-buildargs ${CMAKE_PARAMS}`" ${COMMAND}
RUN make -C build install
